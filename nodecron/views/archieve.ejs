<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<title>Archive Logs</title>

<style>
* {
  box-sizing: border-box;
  font-family: "Segoe UI", sans-serif;
}

body {
  margin: 0;
  height: 100vh;
  background: linear-gradient(135deg, #ffe5df, #fff);
  display: flex;
  align-items: center;
  justify-content: center;
}

.container {
  width: 85%;
  height: 80%;
  background: #fff;
  border-radius: 18px;
  display: flex;
  overflow: hidden;
  box-shadow: 0 25px 60px rgba(0,0,0,0.15);
}

/* LEFT PANEL */
.left {
  width: 40%;
  background: linear-gradient(135deg, #ff3d3d, #ff6a3d);
  color: white;
  padding: 50px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.left h1 {
  font-size: 32px;
  margin-bottom: 20px;
}

.left p {
  line-height: 1.7;
  opacity: 0.95;
}

/* RIGHT PANEL */
.right {
  width: 60%;
  padding: 40px;
  overflow-y: auto;
  position: relative;

  /* subtle pattern */
  background-image:
    repeating-linear-gradient(
      45deg,
      rgba(0,0,0,0.025),
      rgba(0,0,0,0.025) 1px,
      transparent 1px,
      transparent 16px
    );
}

/* MAIN CARD */
.card {
  background: #fff;
  border-radius: 14px;
  padding: 25px 30px;
  margin-bottom: 30px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.08);
  display: flex;
  justify-content: space-between;
  align-items: center;
  animation: slideIn 0.7s ease forwards;
}

@keyframes slideIn {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.card h3 {
  margin: 0;
}

.card p {
  margin-top: 8px;
  color: #777;
  font-size: 14px;
}

/* BUTTON */
.btn {
  background: #ff4b2b;
  border: none;
  color: white;
  padding: 12px 28px;
  border-radius: 25px;
  cursor: pointer;
  font-size: 14px;
  transition: all 0.3s ease;
}

.btn:hover {
  transform: scale(1.07);
  box-shadow: 0 10px 25px rgba(255,75,43,0.45);
}

.btn:active {
  transform: scale(0.95);
}

/* LOADER */
.loader {
  display: none;
  width: 22px;
  height: 22px;
  border: 3px solid rgba(255,255,255,0.4);
  border-top: 3px solid white;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.success {
  color: #2ecc71;
  font-size: 14px;
  margin-top: 10px;
  display: none;
}

/* EXTRA CONTENT */
.info-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
  margin-bottom: 30px;
}

.info-box {
  background: #fff;
  padding: 18px;
  border-radius: 12px;
  box-shadow: 0 6px 18px rgba(0,0,0,0.06);
  text-align: center;
}

.info-box h4 {
  margin: 0;
  font-size: 18px;
  color: #ff4b2b;
}

.info-box span {
  font-size: 13px;
  color: #777;
}

/* PROCESS */
.process {
  background: #fff;
  padding: 22px;
  border-radius: 14px;
  box-shadow: 0 8px 20px rgba(0,0,0,0.06);
}

.process h4 {
  margin-bottom: 15px;
}

.process ul {
  padding-left: 20px;
  margin: 0;
}

.process li {
  margin-bottom: 10px;
  font-size: 14px;
  color: #555;
}
</style>
</head>

<body>

<div class="container">

  <div class="left">
    <h1>Job Scheduling System</h1>
    <p>
      This dashboard allows administrators to manage and monitor
      backend jobs such as cleanup tasks, reports, log archiving,
      and health checks.
    </p>
  </div>

  <div class="right">

    <!-- MAIN ACTION -->
    <div class="card">
      <div>
        <h3>📦 Archive Logs</h3>
        <p>Exports expired logs as JSON and downloads the file</p>
        <div class="success" id="successMsg">✔ Logs archived & downloaded</div>
      </div>

      <button class="btn" id="runBtn" onclick="downloadLogs()">
        <span id="btnText">Run</span>
        <div class="loader" id="loader"></div>
      </button>
    </div>

    <!-- STATS -->
    <div class="info-grid">
      <div class="info-box">
        <h4>30 Days</h4>
        <span>Retention Policy</span>
      </div>
      <div class="info-box">
        <h4>JSON</h4>
        <span>Export Format</span>
      </div>
      <div class="info-box">
        <h4>Manual</h4>
        <span>Trigger Type</span>
      </div>
    </div>

    <!-- PROCESS EXPLANATION -->
    <div class="process">
      <h4>What happens when you run this?</h4>
      <ul>
        <li>Expired logs are identified using retention rules</li>
        <li>Logs are serialized into a JSON file</li>
        <li>Browser downloads the archive automatically</li>
        <li>Main database remains clean & optimized</li>
      </ul>
    </div>

  </div>
</div>

<script>
function downloadLogs() {
  const loader = document.getElementById("loader");
  const text = document.getElementById("btnText");
  const success = document.getElementById("successMsg");
  const btn = document.getElementById("runBtn");

  btn.disabled = true;
  btn.style.opacity = "0.7";
  btn.style.cursor = "not-allowed";

  text.style.display = "none";
  loader.style.display = "inline-block";
  success.style.display = "none";

  window.location.href = "/archieve/file";

  setTimeout(() => {
    loader.style.display = "none";
    text.style.display = "inline";
    success.style.display = "block";

    btn.disabled = false;
    btn.style.opacity = "1";
    btn.style.cursor = "pointer";
  }, 1800);
}
</script>

</body>
</html>
