<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Login</title>

<style>
* {
  box-sizing: border-box;
  font-family: "Segoe UI", sans-serif;
}

body {
  margin: 0;
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;

  /* 🔥 Soft white–red gradient background */
  background:
    radial-gradient(900px 500px at 15% 20%, rgba(255,75,43,0.18), transparent),
    radial-gradient(700px 450px at 85% 80%, rgba(255,65,108,0.15), transparent),
    linear-gradient(180deg, #ffffff, #fff3ef);

  overflow: hidden;
}


.container {
  width: 900px;
  height: 480px;
  background: #fff;
  display: flex;
  border-radius: 12px;
  overflow: hidden;
  box-shadow:
    0 30px 60px rgba(0,0,0,0.22),
    0 0 0 1px rgba(255,75,43,0.12);
}


/* LEFT (LOGIN) */
.left {
  width: 50%;
  padding: 60px 50px;
}

.left h2 {
  margin-bottom: 25px;
  color: #333;
}

.left input {
  width: 100%;
  padding: 12px;
  margin-bottom: 15px;
  border-radius: 6px;
  border: 1px solid #ccc;
}

.left button {
  width: 100%;
  padding: 12px;
  background: #ff4b2b;
  border: none;
  color: #fff;
  border-radius: 20px;
  font-weight: 600;
  cursor: pointer;
}

/* RIGHT (RED PANEL) */
.right {
  width: 50%;
  background: linear-gradient(135deg, #ff4b2b, #ff416c);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 40px;
}

.right h2 {
  margin-bottom: 15px;
}

.right p {
  font-size: 14px;
  margin-bottom: 30px;
}

.right a {
  padding: 10px 30px;
  border: 2px solid #fff;
  border-radius: 20px;
  color: #fff;
  text-decoration: none;
  font-weight: 600;
}
</style>
</head>

<body>

<div class="container">

  <div class="left">
    <h2>Sign in</h2>

    <form method="POST" action="/user/login">
      <input type="email" name="email" placeholder="Email" required>
      <input type="password" name="password" placeholder="Password" required>
      <button type="submit">SIGN IN</button>
    </form>
  </div>

  <div class="right">
    <div>
      <h2>Hello, Friend!</h2>
      <p>Enter your personal details and start managing scheduled tasks</p>
      <a href="/signup">SIGN UP</a>
    </div>
  </div>

</div>

</body>
</html>
