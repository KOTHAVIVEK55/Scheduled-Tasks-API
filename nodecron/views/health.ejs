<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Health Check</title>

<style>
* {
  box-sizing: border-box;
  font-family: "Segoe UI", sans-serif;
}

body {
  margin: 0;
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    radial-gradient(900px 500px at 15% 20%, rgba(255,75,43,0.18), transparent),
    radial-gradient(700px 450px at 85% 80%, rgba(255,65,108,0.15), transparent),
    linear-gradient(180deg, #ffffff, #fff3ef);
}

.container {
  width: 1100px;
  height: 560px;
  background: #fff;
  display: flex;
  border-radius: 14px;
  overflow: hidden;
  box-shadow: 0 30px 60px rgba(0,0,0,0.22);
}

/* LEFT */
.left {
  width: 35%;
  background: linear-gradient(135deg, #ff4b2b, #ff416c);
  color: #fff;
  padding: 50px 40px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

/* RIGHT */
.right {
  width: 65%;
  padding: 40px;
  display: flex;
  justify-content: center;
  align-items: center;
}

.center {
  width: 100%;
  text-align: center;
}

h1 {
  margin: 0;
  font-size: 28px;
  color: #222;
}

.check-btn {
  margin: 25px 0 12px;
  padding: 12px 34px;
  background: #ff4b2b;
  border: none;
  color: #fff;
  border-radius: 30px;
  font-size: 15px;
  font-weight: 600;
  cursor: pointer;
  transition: 0.3s;
}

.check-btn:hover {
  background: #e03e22;
  transform: scale(1.05);
}

.loader {
  display: none;
  color: #ff4b2b;
  font-weight: 600;
}

/* 🔴🟢 STATUS LEGEND (NEW) */
.legend {
  font-size: 13px;
  margin-bottom: 10px;
  color: #555;
}

.legend span {
  font-weight: 600;
  margin: 0 8px;
}

.legend .green {
  color: #2ecc71;
}

.legend .red {
  color: #e74c3c;
}

/* CARDS */
.cards {
  display: flex;
  gap: 20px;
  margin-top: 30px;
}

.card {
  flex: 1;
  background: #fff;
  border-radius: 14px;
  padding: 22px;
  border: 1px solid #ddd;
  animation: slideUp 0.6s ease forwards;
}

/* STATUS COLORS */
.success {
  border-left: 6px solid #2ecc71;
  box-shadow: 0 0 18px rgba(46,204,113,0.35);
}

.failure {
  border-left: 6px solid #e74c3c;
  box-shadow: 0 0 18px rgba(231,76,60,0.35);
}

/* STATUS DOT */
.status-dot {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  margin: 10px auto;
  animation: pulse 1.6s infinite;
}

.green { background: #2ecc71; }
.red { background: #e74c3c; }

/* ENDPOINT LIST */
.endpoint {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 14px;
  margin-top: 10px;
  border-radius: 10px;
  background: #fafafa;
  animation: fadeIn 0.4s forwards;
  transition: 0.3s;
}

.endpoint:hover {
  transform: translateX(6px);
}

.endpoint.up {
  border-left: 5px solid #2ecc71;
}

.endpoint.down {
  border-left: 5px solid #e74c3c;
}

.badge {
  padding: 5px 14px;
  border-radius: 20px;
  font-size: 12px;
  font-weight: 700;
}

.badge.up {
  background: rgba(46,204,113,0.2);
  color: #2ecc71;
}

.badge.down {
  background: rgba(231,76,60,0.2);
  color: #e74c3c;
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(18px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes pulse {
  0% { transform: scale(1); opacity: 0.8; }
  50% { transform: scale(1.5); opacity: 0.4; }
  100% { transform: scale(1); opacity: 0.8; }
}
</style>
</head>

<body>

<div class="container">

  <div class="left">
    <h2>Health Monitoring</h2>
    <p>
      Verify backend readiness including database
      connectivity and API availability.
    </p>
  </div>

  <div class="right">
    <div class="center">

      <h1>System Health Check</h1>

      <button class="check-btn" onclick="runHealthCheck()">Check Health</button>

      <!-- 🟢🔴 LEGEND -->
      <div class="legend">
        <span class="green">● Green</span> = Healthy / Connected / UP
        <span class="red">● Red</span> = Issue Detected / DOWN
      </div>

      <div id="loader" class="loader">Running health checks...</div>

      <div id="result" class="cards"></div>

    </div>
  </div>

</div>

<script>
async function runHealthCheck() {
  document.getElementById("loader").style.display = "block";
  document.getElementById("result").innerHTML = "";

  const base = window.location.origin;
  const db = await fetch(`${base}/health-api`).then(r => r.json());
  const ep = await fetch(`${base}/health-api/endpoints`).then(r => r.json());

  document.getElementById("loader").style.display = "none";

  let endpointsHTML = "";
  ep.endpoints.forEach((e, i) => {
    endpointsHTML += `
      <div class="endpoint ${e.status === "UP" ? "up" : "down"}" style="animation-delay:${i * 0.12}s">
        <span>${e.name}</span>
        <span class="badge ${e.status === "UP" ? "up" : "down"}">${e.status}</span>
      </div>
    `;
  });

  const isDbUp = db.status === "success";

  document.getElementById("result").innerHTML = `
    <div class="card ${isDbUp ? "success" : "failure"}">
      <h3>Database</h3>
      <div class="status-dot ${isDbUp ? "green" : "red"}"></div>
      <p><b>${db.connectionState.toUpperCase()}</b></p>
      <span>Last checked: ${new Date(db.checkedAt).toLocaleString()}</span>
    </div>

    <div class="card ${ep.endpoints.every(e => e.status === "UP") ? "success" : "failure"}">
      <h3>API Endpoints</h3>
      ${endpointsHTML}
    </div>
  `;
}
</script>

</body>
</html>
