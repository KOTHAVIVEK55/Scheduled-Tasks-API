<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Daily Summary Report</title>

<style>
* {
  box-sizing: border-box;
  font-family: "Segoe UI", sans-serif;
}

body {
  margin: 0;
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    radial-gradient(900px 500px at 20% 20%, rgba(255,75,43,.22), transparent),
    radial-gradient(700px 400px at 80% 80%, rgba(255,65,108,.18), transparent),
    linear-gradient(180deg, #fff2ee, #ffffff);
}

/* MAIN */
.container {
  width: 1200px;
  background: linear-gradient(180deg, #ffffff, #fff6f3);
  border-radius: 22px;
  padding: 46px;
  box-shadow: 0 35px 70px rgba(0,0,0,.28);
  animation: slideUp .8s ease;
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(40px); }
  to { opacity: 1; transform: translateY(0); }
}

/* HEADER */
.header {
  display: flex;
  align-items: center;
  gap: 18px;
}

.header-icon {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff4b2b, #ff416c);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30px;
  color: #fff;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0% { box-shadow: 0 0 0 0 rgba(255,75,43,.6); }
  70% { box-shadow: 0 0 0 20px rgba(255,75,43,0); }
  100% { box-shadow: 0 0 0 0 rgba(255,75,43,0); }
}

.date {
  margin: 18px 0 36px;
  font-size: 14px;
  color: #777;
}

/* CONTENT ROW */
.content {
  display: flex;
  gap: 50px;
}

/* LEFT STATS */
.stats {
  width: 55%;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 26px;
}

.card {
  background: linear-gradient(135deg, #ffffff, #fff2ee);
  border-radius: 18px;
  padding: 26px;
  border-left: 6px solid #ff4b2b;
  box-shadow: 0 14px 28px rgba(0,0,0,.14);
  opacity: 0;
  transform: translateY(18px);
  animation: cardIn .7s ease forwards;
}

.card:nth-child(1){ animation-delay:.1s }
.card:nth-child(2){ animation-delay:.2s }
.card:nth-child(3){ animation-delay:.3s }
.card:nth-child(4){ animation-delay:.4s }

@keyframes cardIn {
  to { opacity: 1; transform: translateY(0); }
}

.value {
  font-size: 42px;
  font-weight: bold;
  color: #ff4b2b;
}

/* RIGHT VISUAL */
.visual {
  width: 45%;
  background: linear-gradient(135deg, #ffffff, #fff2ee);
  border-radius: 22px;
  padding: 32px;
  box-shadow: 0 18px 36px rgba(0,0,0,.16);
}

.visual h3 {
  margin-bottom: 30px;
}

/* CHART */
.chart-area {
  height: 260px;
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
}

/* BAR GROUP */
.chart-bar {
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* VALUE ABOVE BAR */
.bar-value {
  font-size: 15px;
  font-weight: 600;
  color: #ff4b2b;
  opacity: 0;
  transform: translateY(6px);
  animation: fadeUp .6s ease forwards;
  animation-delay: .9s;
}

@keyframes fadeUp {
  to { opacity: 1; transform: translateY(0); }
}

/* BAR */
.bar {
  width: 18px;
  height: 0;
  border-radius: 14px;
  background: linear-gradient(180deg, #ff4b2b, #ff416c);
  transition: height 1.6s cubic-bezier(.25,.8,.25,1);
  margin: 6px 0;
}

.bar:hover {
  box-shadow: 0 0 18px rgba(255,75,43,.7);
}

/* LABEL */
.bar-label {
  font-size: 13px;
  color: #555;
}

/* FOOTER */
.footer {
  margin-top: 42px;
  text-align: center;
  font-size: 13px;
  color: #777;
}
</style>
</head>

<body>

<div class="container">

  <div class="header">
    <div class="header-icon">📊</div>
    <h1>Daily Summary Report</h1>
  </div>

  <div class="date">📅 <strong><%= date %></strong></div>

  <div class="content">

    <!-- LEFT -->
    <div class="stats">
      <div class="card">
        <h3>👤 Total Users</h3>
        <div class="value" data-count="<%= totalUsers %>">0</div>
        <p>All registered users</p>
      </div>

      <div class="card">
        <h3>🆕 Users Created Today</h3>
        <div class="value" data-count="<%= usersCreatedToday %>">0</div>
        <p>New signups today</p>
      </div>

      <div class="card">
        <h3>🟢 Active Sessions</h3>
        <div class="value" data-count="<%= activeSessions %>">0</div>
        <p>Currently active sessions</p>
      </div>

      <div class="card">
        <h3>🔴 Expired Sessions</h3>
        <div class="value" data-count="<%= expiredSessions %>">0</div>
        <p>Expired login sessions</p>
      </div>
    </div>

    <!-- RIGHT -->
    <div class="visual">
      <h3>📈 Visual Overview</h3>

      <div class="chart-area">
        <div class="chart-bar">
          <span class="bar-value"><%= totalUsers %></span>
          <div class="bar" data-value="<%= totalUsers %>"></div>
          <span class="bar-label">Users</span>
        </div>

        <div class="chart-bar">
          <span class="bar-value"><%= usersCreatedToday %></span>
          <div class="bar" data-value="<%= usersCreatedToday %>"></div>
          <span class="bar-label">New</span>
        </div>

        <div class="chart-bar">
          <span class="bar-value"><%= activeSessions %></span>
          <div class="bar" data-value="<%= activeSessions %>"></div>
          <span class="bar-label">Active</span>
        </div>

        <div class="chart-bar">
          <span class="bar-value"><%= expiredSessions %></span>
          <div class="bar" data-value="<%= expiredSessions %>"></div>
          <span class="bar-label">Expired</span>
        </div>
      </div>
    </div>

  </div>

  <div class="footer">
    Generated at: <%= new Date(generatedAt).toLocaleString() %>
  </div>

</div>

<script>
/* COUNTER ANIMATION */
document.querySelectorAll(".value").forEach(el => {
  const target = +el.dataset.count;
  let count = 0;
  const step = Math.max(1, Math.ceil(target / 40));

  const t = setInterval(() => {
    count += step;
    if (count >= target) {
      el.innerText = target;
      clearInterval(t);
    } else el.innerText = count;
  }, 25);
});

/* BAR ANIMATION */
window.onload = () => {
  const bars = document.querySelectorAll(".bar");
  const values = [...bars].map(b => +b.dataset.value);
  const max = Math.max(...values, 1);

  bars.forEach((bar, i) => {
    setTimeout(() => {
      bar.style.height = (bar.dataset.value / max * 200) + "px";
    }, 500 + i * 180);
  });
};
</script>

</body>
</html>
